# =============================================================================
# Supabase self-hosted (ou cloud)
# URL base do projeto: ex. https://seu-vps.exemplo.com ou https://xyz.supabase.co
# =============================================================================

# Supabase — prefixo VITE_ (compatibilidade Vite / Docker build arg)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase — prefixo NEXT_PUBLIC_ (Next.js cliente)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NUNCA expor ao cliente (sem prefixo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Aplicação
# =============================================================================

# Versão da imagem Docker (usado no docker-compose e no build)
APP_VERSION=2026-05-04-01

# URL base da aplicação
# Dev: http://localhost:3000 | Prod: https://seu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Habilite apenas durante o bootstrap inicial do primeiro admin
# Desative após criar o primeiro usuário admin
NEXT_PUBLIC_ENABLE_INITIAL_SETUP=false

