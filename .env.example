# Supabase — prefixo VITE_ (Vite / Docker build)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase — prefixo NEXT_PUBLIC_ (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Versão da imagem Docker
APP_VERSION=2026-05-04-01

# Habilite apenas durante o bootstrap inicial do primeiro admin
NEXT_PUBLIC_ENABLE_INITIAL_SETUP=false

# Server-only — nunca com prefixo público
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

