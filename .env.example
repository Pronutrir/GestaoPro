# Supabase — prefixo VITE_ (Vite / Docker build)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase — prefixo NEXT_PUBLIC_ (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Versão da imagem Docker
APP_VERSION=2026-05-22-01

# Habilite apenas durante o bootstrap inicial do primeiro admin
NEXT_PUBLIC_ENABLE_INITIAL_SETUP=false

# Server-only — nunca com prefixo público
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Origem permitida no CORS das rotas admin (opcional). Se vazio, usa
# NEXT_PUBLIC_SUPABASE_URL (mesmo domínio do app em same-origin).
# ALLOWED_ORIGIN=https://gestaopro.pronutrir.com.br

# OpenRouter (server-only) — agente IA com tool calling
# Crie a chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# Modelo padrão (lista em https://openrouter.ai/models)
OPENROUTER_MODEL=openai/gpt-4o-mini

# ----------------------------------------------------------------------------
# Azure AD (Microsoft Entra ID) — usado pelo provider OAuth no GoTrue.
# Estas variáveis são consumidas no docker-compose do Supabase self-hosted
# (não pelo Next.js). Mantidas aqui apenas como referência de configuração.
# ----------------------------------------------------------------------------
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_REDIRECT_URI=https://seu-supabase.example.com/auth/v1/callback
