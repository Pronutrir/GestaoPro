# Supabase - cliente publico
VITE_SUPABASE_URL=https://your-project.example.com
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Next.js publico
NEXT_PUBLIC_SUPABASE_URL=https://your-project.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Habilite apenas durante o bootstrap inicial do primeiro admin
NEXT_PUBLIC_ENABLE_INITIAL_SETUP=false
INITIAL_SETUP_ENABLED=false

# URL base da aplicação (usada para montar redirectTo no OAuth)
# Dev: http://localhost:3000 | Prod: https://seu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Microsoft Entra ID - configuracao no Supabase Dashboard
# Authentication -> Providers -> Azure
#   Client ID: Application/Client ID do App Registration no Azure
#   Client Secret: Client secret criado em "Certificates & secrets"
#   Azure Tenant: Tenant ID da sua organizacao (single-tenant)
#
# Redirect URL no Azure App Registration:
#   https://your-project.example.com/auth/v1/callback
#
# Redirect URLs no Supabase Dashboard (Site URL / Additional URLs):
#   http://localhost:3000/auth/callback      (desenvolvimento)
#   https://seu-dominio.com/auth/callback    (producao)
# =============================================================================

